# Supabase
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Your deployed app domain (used in email CTAs, og:url, sitemap, etc.)
PUBLIC_APP_URL="https://your-domain.com"

# Gmail connector (via Lovable gateway, or replace with your own email provider)
LOVABLE_API_KEY="your-lovable-api-key"
GOOGLE_MAIL_API_KEY="your-google-mail-api-key"

# Cron secret — add this header to your pg_cron / scheduler calls:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET="a-long-random-secret-string"
